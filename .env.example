# 生產環境配置範例
# 複製此檔案為 .env 並填入實際值

# ==================== 基本配置 ====================

# 服務模式
DEV_MODE=false
PYTHONUNBUFFERED=1

# 服務主機與埠
HOST=0.0.0.0
PORT=8000

# ==================== 安全配置 ====================

# JWT Secret Key (請使用強隨機字串)
# 產生方式：openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# 預設 API Key (請修改)
DEFAULT_API_KEY=soapvoice-production-key-change-me

# CORS 設定 (逗號分隔)
CORS_ORIGINS=https://doctor-toolbox.com,https://www.doctor-toolbox.com

# ==================== 模型配置 ====================

# LLM 模型
LLM_MODEL=qwen3.5:9b
LLM_GPU_MEMORY=0.9

# Ollama 服務
OLLAMA_HOST=localhost:11434

# ==================== 資料庫配置 ====================

# PostgreSQL (可選，用於使用者管理)
DATABASE_URL=postgresql://user:password@localhost:5432/soapvoice

# Redis (可選，用於快取與 rate limiting)
REDIS_URL=redis://localhost:6379/0

# ==================== 日誌配置 ====================

# 日誌級別：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日誌格式
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ==================== 監控配置 ====================

# Prometheus (可選)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ==================== 速率限制 ====================

# 每 IP 每小時請求數限制
RATE_LIMIT_PER_HOUR=1000

# 每 IP 每分鐘請求數限制
RATE_LIMIT_PER_MINUTE=60

# ==================== HuggingFace (可選) ====================

# HuggingFace Token (用於下載模型)
# HF_TOKEN=your-huggingface-token

# ==================== 郵件通知 (可選) ====================

# SMTP 配置 (用於發送通知郵件)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== 備份配置 (可選) ====================

# 備份目錄
BACKUP_DIR=/var/backups/soapvoice

# 備份保留天數
BACKUP_RETENTION_DAYS=30
