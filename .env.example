# SoapVoice 環境配置範例
# 複製此檔案為 .env 並填入實際值

# ==================== 基本配置 ====================

# 服務模式
DEV_MODE=false
PYTHONUNBUFFERED=1

# 服務主機與埠
HOST=0.0.0.0
PORT=8000

# ==================== 安全配置 ====================

# JWT Secret Key (請使用強隨機字串)
# 產生方式：openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# 預設 API Key (請修改)
DEFAULT_API_KEY=soapvoice-production-key-change-me

# CORS 設定 (逗號分隔)
CORS_ORIGINS=http://localhost:3000,https://doctor-toolbox.com

# ==================== LLM 配置 ====================

# LLM 優先級策略
# local_first: 優先本地，失敗時 fallback 到雲端
# cloud_first: 優先雲端，本地作為備用
# local_only: 僅使用本地
# cloud_only: 僅使用雲端
LLM_PRIORITY=local_first

# Ollama 服務 (用於 OllamaEngine)
OLLAMA_HOST=localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Llama.cpp 本地模型 (用於 LlamaEngine)
# 下載：huggingface.co/Qwen/Qwen2.5-7B-Instruct-GGUF
LLAMA_MODEL_PATH=models/qwen2.5-7b-q4_k_m.gguf
LLAMA_N_GPU_LAYERS=35
LLAMA_N_CTX=4096
LLAMA_N_THREADS=8
LLAMA_TEMPERATURE=0.3
LLAMA_MAX_TOKENS=1024

# DoctorConsultation API (用於雲端 LLM)
# 申請：https://doctor-toolbox.com/DoctorConsultation
DOCTOR_CONSULTATION_API_KEY=your-api-key-here
DOCTOR_CONSULTATION_BASE_URL=https://doctor-toolbox.com/DoctorConsultation
DOCTOR_CONSULTATION_TIMEOUT=120

# ==================== ASR 配置 ====================

# Faster-Whisper 模型大小
# 可選：tiny, base, small, medium, large-v2, large-v3
ASR_MODEL=medium
ASR_DEVICE=cuda
ASR_LANGUAGE=zh

# ==================== 資料庫配置 ====================

# SQLite 本地資料庫
DATABASE_PATH=data/local_db/medical.db

# Redis (用於快取與 rate limiting)
REDIS_URL=redis://localhost:6379/0

# ==================== 日誌配置 ====================

# 日誌級別：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 速率限制 ====================

# 每 IP 每小時請求數限制
RATE_LIMIT_PER_HOUR=1000

# 每 IP 每分鐘請求數限制
RATE_LIMIT_PER_MINUTE=60

# ==================== HuggingFace (可選) ====================

# HuggingFace Token (用於下載模型)
# HF_TOKEN=your-huggingface-token

# ==================== 備份配置 (可選) ====================

# 備份目錄
BACKUP_DIR=/var/backups/soapvoice

# 備份保留天數
BACKUP_RETENTION_DAYS=30
