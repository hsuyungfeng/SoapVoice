<div class="mw-heading mw-heading3"><h3 id="第二级"><span id=".E7.AC.AC.E4.BA.8C.E7.BA.A7"></span>第二級</h3><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=%E8%A7%A3%E5%89%96%E5%AD%A6%E6%B2%BB%E7%96%97%E5%AD%A6%E5%8F%8A%E5%8C%96%E5%AD%A6%E5%88%86%E7%B1%BB%E7%B3%BB%E7%BB%9F&amp;action=edit&amp;section=3" title="編輯章節：第二級"><span>編輯</span></a><span class="mw-editsection-bracket">]</span></span></div>
