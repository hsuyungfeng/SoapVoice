# SoapVoice 專案環境變數配置

# CUDA 配置
CUDA_PATH=/usr/local/cuda
CUDA_VERSION=12.2

# Python 配置
PYTHON_VERSION=3.11
PYTHON_PATH=/usr/bin/python3

# 專案配置
PROJECT_NAME=SoapVoice
ENVIRONMENT=development

# API 配置 (後續由 Phase 2-4 填入)
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# 日誌配置
LOG_LEVEL=INFO
LLM_MODEL=qwen2.5:3b
